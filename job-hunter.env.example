# Core LLM
LLM_BASE_URL=https://api.openai.com/v1
JOB_HUNTER_LLM_KEY=put-your-llm-api-key-here
LLM_MODEL=gpt-4.1-mini

# State directory (cookies, seen_vacancies, resume, debug files)
# JOB_HUNTER_HOME=~/.job-hunter

# Telegram notifications (optional)
# HUNTER_BOT_TOKEN=123456:telegram-bot-token
# NOTIFY_CHAT_ID=123456789
# TELEGRAM_PROXY=socks5://127.0.0.1:7897

# AI Office integration (optional)
# OFFICE_URL=http://localhost:3000
# OFFICE_DB=/path/to/ai-office/database.sqlite
# AGENT_ID=hunter

# Global runtime
# HEADLESS=1
# SLOW_MO=500
# BROWSER_PROXY=http://127.0.0.1:7897

# Source toggles
# HH_ENABLED=1
# SUPERJOB_ENABLED=1
# HABR_ENABLED=1
# GEEKJOB_ENABLED=1

# Application limits
# MAX_APPLICATIONS_PER_RUN=0
# MAX_AUTO_APPLICATIONS_PER_SOURCE=20

# Habr
# HABR_AUTO_APPLY=1
# HABR_MIN_SECONDS_BETWEEN_APPLICATIONS=10

# SuperJob
# SUPERJOB_API_KEY=put-your-superjob-api-key-here
# SUPERJOB_CLIENT_ID=123456
# SUPERJOB_AUTO_APPLY=1
# SUPERJOB_RESUME_ID=12345678
