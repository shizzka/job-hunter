# Core LLM
# Pick one provider shape below and keep only the values you need.

# Option A: OpenAI or any OpenAI-compatible hosted provider
LLM_BASE_URL=https://api.openai.com/v1
JOB_HUNTER_LLM_KEY=put-your-llm-api-key-here
LLM_MODEL=gpt-4.1-mini

# Option B: Ollama Cloud / ollama.com
# LLM_BASE_URL=https://ollama.com/v1
# JOB_HUNTER_LLM_KEY=put-your-ollama-cloud-key-here
# LLM_MODEL=deepseek-v3.1:671b

# Option C: local Ollama server
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# JOB_HUNTER_LLM_KEY=ollama
# LLM_MODEL=qwen2.5:14b

# State directory (cookies, seen_vacancies, resume, debug files)
# JOB_HUNTER_HOME=~/.job-hunter
# ANALYTICS_ENABLED=1
# ANALYTICS_RECENT_DAYS=30
# ANALYTICS_MAX_DETAILS_CHARS=12000

# Telegram notifications (optional)
# HUNTER_BOT_TOKEN=123456:telegram-bot-token
# HUNTER_CONTROL_BOT_TOKEN=123456:telegram-bot-token
# HUNTER_NOTIFY_BOT_TOKEN=123456:telegram-bot-token
# NOTIFY_CHAT_ID=123456789
# JOB_HUNTER_TELEGRAM_AI_FREE_ANALYSES=1
# JOB_HUNTER_BOT_DEBUG_LOG_FILE=~/.job-hunter/telegram-bot-debug.jsonl
# TELEGRAM_PROXY=socks5://127.0.0.1:7897

# AI Office integration (optional)
# OFFICE_URL=http://localhost:3000
# OFFICE_DB=/path/to/ai-office/database.sqlite
# AGENT_ID=hunter

# Global runtime
# HEADLESS=1
# SLOW_MO=500
# BROWSER_PROXY=http://127.0.0.1:7897

# Source toggles
# HH_ENABLED=1
# SUPERJOB_ENABLED=1
# HABR_ENABLED=1
# GEEKJOB_ENABLED=1

# Search queries
# Defaults are QA-focused, but you can replace them with your own targets.
# Use "||" as a separator for multiple values.
# HH_SEARCH_QUERIES=QA engineer||SDET||automation tester
# SUPERJOB_SEARCH_QUERIES=QA||qa engineer||sdet
#
# Habr Career uses category/listing paths instead of free-text queries.
# Example remote paths:
# HABR_SEARCH_PATHS=/vacancies/testirovschik_qa/remote||/vacancies/devops/remote
# HABR_SEARCH_PATHS=/vacancies/developer/remote||/vacancies/analyst/remote

# Application limits
# MAX_APPLICATIONS_PER_RUN=0
# MAX_AUTO_APPLICATIONS_PER_SOURCE=20
# SEARCH_INTERVAL_MIN=480
# INVITE_CHECK_INTERVAL_MIN=480

# hh staged resume pipeline (normal -> fun -> ats-heavy)
# HH_RESUME_PIPELINE_ENABLED=1
# HH_RESUME_RETRY_DELAY_HOURS=24
# HH_PRIMARY_RESUME_TITLE=QA Engineer / Manual QA / Test Engineer
# HH_SECONDARY_RESUME_TITLE=QA Fun Variant
# HH_TERTIARY_RESUME_TITLE=QA ATS Heavy Variant

# Habr
# HABR_AUTO_APPLY=1
# HABR_MIN_SECONDS_BETWEEN_APPLICATIONS=10

# GeekJob
# GEEKJOB_AUTO_APPLY=1
# GEEKJOB_RESUME_ID=

# SuperJob
# SUPERJOB_API_KEY=put-your-superjob-api-key-here
# SUPERJOB_CLIENT_ID=123456
# SUPERJOB_AUTO_APPLY=1
# SUPERJOB_RESUME_ID=12345678
